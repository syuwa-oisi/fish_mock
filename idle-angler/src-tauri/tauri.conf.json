{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Idle Angler",
  "version": "0.1.0",
  "identifier": "com.pentronic.idleangler",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Idle Angler",
        "width": 424,
        "height": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
